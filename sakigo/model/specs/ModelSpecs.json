{
  "schema_version": 5,
  "default_model": "balanced",
  "includes": {
    "stem_shapes": "StemShapes.json",
    "head_shapes": "HeadShapes.json"
  },
  "notes": [
    "Each model recursively overrides model_defaults; model order is public.",
    "The fixed trunk program is one initial register broadcast, block_count ordinary board blocks, then one final register gather.",
    "expanded_channel and register_channel are persistent widths; bottleneck_channel and register_bottleneck_channel are working attention widths.",
    "activation applies to the board-block f1 output.",
    "max_board_size caps square inputs; rules initialize registers; pass logits are appended after board logits."
  ],
  "comparison": {
    "target_trunk_parameters": 5405426,
    "relative_tolerance": 0.002,
    "fixed_expanded_channel": 128,
    "varied": ["bottleneck_channel", "block_count"]
  },
  "model_defaults": {
    "architecture": "d4_equivariant",
    "activation": "silu",
    "max_board_size": 32,
    "stem_shape": "scalar_lift_v1",
    "head_shape": "standard_v1",
    "norm_eps": 0.000001,
    "trunk": {
      "block_count": 16,
      "register_count": 2,
      "expanded_channel": 128,
      "register_channel": 64,
      "bottleneck_channel": 64,
      "register_bottleneck_channel": 32,
      "q_heads": 2,
      "kv_heads": 1,
      "global_rope_frequencies": ["pi"],
      "local_rope_frequencies": ["pi/2"]
    }
  },
  "models": {
    "narrow-deep": {
      "trunk": {
        "block_count": 33,
        "bottleneck_channel": 40
      }
    },
    "balanced": {},
    "wide-shallow": {
      "trunk": {
        "block_count": 5,
        "bottleneck_channel": 128
      }
    }
  }
}
